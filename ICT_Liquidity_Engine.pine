//@version=6
indicator("ICT Liquidity Engine - Base", overlay=true, max_lines_count=50, max_labels_count=50)


//━━━━━━━━━━━━━━━━━━
// PD LEVEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPDH = input.bool(true, "Show PDH")
showPDL = input.bool(true, "Show PDL")

pdhColor = input.color(color.green, "PDH Color")
pdlColor = input.color(color.red, "PDL Color")

lineWidth = input.int(2, "PD Line Width", minval=1, maxval=5)

showPDLabels = input.bool(true, "Show PDH/PDL Labels")

pdhLabelColor = input.color(color.green, "PDH Label Color")
pdlLabelColor = input.color(color.red, "PDL Label Color")

//━━━━━━━━━━━━━━━━━━
// PM LEVEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPMH = input.bool(true, "Show PMH")
showPML = input.bool(true, "Show PML")

pmhColor = input.color(color.orange, "PMH Color")
pmlColor = input.color(color.blue, "PML Color")

monthLineWidth = input.int(2, "Month Line Width", minval=1, maxval=5)


showPMLabels = input.bool(true, "Show PMH/PML Labels")

pmhLabelColor = input.color(color.orange, "PMH Label Color")
pmlLabelColor = input.color(color.blue, "PML Label Color")

//━━━━━━━━━━━━━━━━━━
// NY DAY ENGINE
//━━━━━━━━━━━━━━━━━━

var float dayHigh = na
var float dayLow = na

var int dayHighTime = na
var int dayLowTime = na


var float pdh = na
var float pdl = na

var int pdhTime = na
var int pdlTime = na


nyDay = dayofmonth(time, "America/New_York")
nyMonth = month(time, "America/New_York")
nyYear = year(time, "America/New_York")

dayID = nyYear * 10000 + nyMonth * 100 + nyDay

newDay = dayID != dayID[1]


if na(dayHigh)

    dayHigh := high
    dayLow := low

    dayHighTime := time
    dayLowTime := time


else

    if newDay

        pdh := dayHigh
        pdl := dayLow

        pdhTime := dayHighTime
        pdlTime := dayLowTime


        dayHigh := high
        dayLow := low

        dayHighTime := time
        dayLowTime := time


    else

        if high > dayHigh

            dayHigh := high
            dayHighTime := time


        if low < dayLow

            dayLow := low
            dayLowTime := time

//━━━━━━━━━━━━━━━━━━
// TIMEFRAME VISIBILITY
//━━━━━━━━━━━━━━━━━━

// PDH / PDL → до 4H включительно
showPDLevels = timeframe.in_seconds() <= timeframe.in_seconds("240")

// PWH / PWL → до 3D включительно
showPWLevels = timeframe.in_seconds() <= timeframe.in_seconds("3D")

// PMH / PML → всегда
showPMLevels = true

//━━━━━━━━━━━━━━━━━━
// DRAW PDH / PDL
//━━━━━━━━━━━━━━━━━━

var line pdhLine = na
var line pdlLine = na

var label pdhLabel = na
var label pdlLabel = na



//━━━━━━━━━━━━━━━━━━
// DRAW PDH
//━━━━━━━━━━━━━━━━━━

if showPDH and showPDLevels and not na(pdh)

    if na(pdhLine)

        pdhLine := line.new(
             x1 = pdhTime,
             y1 = pdh,
             x2 = time,
             y2 = pdh,
             xloc = xloc.bar_time,
             extend = extend.right,
             color = pdhColor,
             width = lineWidth)

    else

        line.set_xy1(
             pdhLine,
             pdhTime,
             pdh)

        line.set_xy2(
             pdhLine,
             time,
             pdh)


    if showPDLabels

        if na(pdhLabel)

            pdhLabel := label.new(
                 x = time,
                 y = pdh,
                 text = "PDH",
                 xloc = xloc.bar_time,
                 style = label.style_label_left,
                 color = pdhLabelColor,
                 textcolor = color.white)

        else

            label.set_xy(
                 pdhLabel,
                 time,
                 pdh)



//━━━━━━━━━━━━━━━━━━
// DRAW PDL
//━━━━━━━━━━━━━━━━━━

if showPDL and showPDLevels and not na(pdl)

    if na(pdlLine)

        pdlLine := line.new(
             x1 = pdlTime,
             y1 = pdl,
             x2 = time,
             y2 = pdl,
             xloc = xloc.bar_time,
             extend = extend.right,
             color = pdlColor,
             width = lineWidth)

    else

        line.set_xy1(
             pdlLine,
             pdlTime,
             pdl)

        line.set_xy2(
             pdlLine,
             time,
             pdl)


    if showPDLabels

        if na(pdlLabel)

            pdlLabel := label.new(
                 x = time,
                 y = pdl,
                 text = "PDL",
                 xloc = xloc.bar_time,
                 style = label.style_label_left,
                 color = pdlLabelColor,
                 textcolor = color.white)

        else

            label.set_xy(
                 pdlLabel,
                 time,
                 pdl)
//━━━━━━━━━━━━━━━━━━
// WEEK ENGINE
//━━━━━━━━━━━━━━━━━━

showPWH = input.bool(true, "Show PWH")
showPWL = input.bool(true, "Show PWL")

pwhColor = input.color(color.yellow, "PWH Color")
pwlColor = input.color(color.purple, "PWL Color")

weekLineWidth = input.int(2, "Week Line Width", minval=1, maxval=5)
showPWLabels = input.bool(true, "Show PWH/PWL Labels")

pwhLabelColor = input.color(color.yellow, "PWH Label Color")
pwlLabelColor = input.color(color.purple, "PWL Label Color")


//━━━━━━━━━━━━━━━━━━
// WEEK DATA
//━━━━━━━━━━━━━━━━━━

var float weekHigh = na
var float weekLow = na

var int weekHighTime = na
var int weekLowTime = na


var float pwh = na
var float pwl = na

var int pwhTime = na
var int pwlTime = na



nyWeek = weekofyear(time, "America/New_York")
nyYearWeek = year(time, "America/New_York")

weekID = nyYearWeek * 100 + nyWeek

newWeek = weekID != weekID[1]



if na(weekHigh)

    weekHigh := high
    weekLow := low

    weekHighTime := time
    weekLowTime := time


else

    if newWeek

        pwh := weekHigh
        pwl := weekLow

        pwhTime := weekHighTime
        pwlTime := weekLowTime


        weekHigh := high
        weekLow := low

        weekHighTime := time
        weekLowTime := time


    else

        if high > weekHigh

            weekHigh := high
            weekHighTime := time


        if low < weekLow

            weekLow := low
            weekLowTime := time


//━━━━━━━━━━━━━━━━━━
// WEEK DRAW OBJECTS
//━━━━━━━━━━━━━━━━━━

var line pwhLine = na
var line pwlLine = na

var label pwhLabel = na
var label pwlLabel = na
//━━━━━━━━━━━━━━━━━━
// DRAW PWH
//━━━━━━━━━━━━━━━━━━

if showPWH and showPWLevels and not na(pwh)

    if na(pwhLine)

        pwhLine := line.new(
             x1 = pwhTime,
             y1 = pwh,
             x2 = time,
             y2 = pwh,
             xloc = xloc.bar_time,
             extend = extend.right,
             color = pwhColor,
             width = weekLineWidth)

    else

        line.set_xy1(
             pwhLine,
             pwhTime,
             pwh)

        line.set_xy2(
             pwhLine,
             time,
             pwh)


    if showPWLabels

        if na(pwhLabel)

            pwhLabel := label.new(
                 x = time,
                 y = pwh,
                 text = "PWH",
                 xloc = xloc.bar_time,
                 style = label.style_label_left,
                 color = pwhLabelColor,
                 textcolor = color.white)

        else

            label.set_xy(
                 pwhLabel,
                 time,
                 pwh)


//━━━━━━━━━━━━━━━━━━
// DRAW PWL
//━━━━━━━━━━━━━━━━━━

if showPWL and showPWLevels and not na(pwl)

    if na(pwlLine)

        pwlLine := line.new(
             x1 = pwlTime,
             y1 = pwl,
             x2 = time,
             y2 = pwl,
             xloc = xloc.bar_time,
             extend = extend.right,
             color = pwlColor,
             width = weekLineWidth)

    else

        line.set_xy1(
             pwlLine,
             pwlTime,
             pwl)

        line.set_xy2(
             pwlLine,
             time,
             pwl)


    if showPWLabels

        if na(pwlLabel)

            pwlLabel := label.new(
                 x = time,
                 y = pwl,
                 text = "PWL",
                 xloc = xloc.bar_time,
                 style = label.style_label_left,
                 color = pwlLabelColor,
                 textcolor = color.white)

        else

            label.set_xy(
                 pwlLabel,
                 time,
                 pwl)    
                 
                
            
        
    
//━━━━━━━━━━━━━━━━━━
// MONTH ENGINE
//━━━━━━━━━━━━━━━━━━

var float monthHigh = na
var float monthLow = na

var int monthHighTime = na
var int monthLowTime = na


var float pmh = na
var float pml = na

var int pmhTime = na
var int pmlTime = na


// Source selection
useWeeklyMonth = timeframe.isweekly or timeframe.ismonthly


monthSourceTime = useWeeklyMonth ? time("W") : time("D")

monthSourceHigh = useWeeklyMonth ? request.security(syminfo.tickerid, "W", high) : request.security(syminfo.tickerid, "D", high)

monthSourceLow = useWeeklyMonth ? request.security(syminfo.tickerid, "W", low) : request.security(syminfo.tickerid, "D", low)


monthValue = month(monthSourceTime, "America/New_York")
yearValue = year(monthSourceTime, "America/New_York")

monthID = yearValue * 100 + monthValue

newMonth = monthID != monthID[1]



if na(monthHigh)

    monthHigh := monthSourceHigh
    monthLow := monthSourceLow

    monthHighTime := monthSourceTime
    monthLowTime := monthSourceTime


else

    if newMonth

        pmh := monthHigh
        pml := monthLow

        pmhTime := monthHighTime
        pmlTime := monthLowTime


        monthHigh := monthSourceHigh
        monthLow := monthSourceLow

        monthHighTime := monthSourceTime
        monthLowTime := monthSourceTime


    else

        if monthSourceHigh > monthHigh

            monthHigh := monthSourceHigh
            monthHighTime := monthSourceTime


        if monthSourceLow < monthLow

            monthLow := monthSourceLow
            monthLowTime := monthSourceTime
            
        
    

          
        
    
//━━━━━━━━━━━━━━━━━━
// MONTH DRAW OBJECTS
//━━━━━━━━━━━━━━━━━━

var line pmhLine = na
var line pmlLine = na

var label pmhLabel = na
var label pmlLabel = na

//━━━━━━━━━━━━━━━━━━
// DRAW PMH
//━━━━━━━━━━━━━━━━━━

if showPMH and not na(pmh)

    if na(pmhLine)

        pmhLine := line.new(
             x1 = pmhTime,
             y1 = pmh,
             x2 = time,
             y2 = pmh,
             xloc = xloc.bar_time,
             extend = extend.right,
             color = pmhColor,
             width = monthLineWidth)

    else

        line.set_xy1(
             pmhLine,
             pmhTime,
             pmh)

        line.set_xy2(
             pmhLine,
             time,
             pmh)


    if showPMLabels

        if na(pmhLabel)

            pmhLabel := label.new(
                 x = time,
                 y = pmh,
                 text = "PMH",
                 xloc = xloc.bar_time,
                 style = label.style_label_left,
                 color = pmhLabelColor,
                 textcolor = color.white)

        else

            label.set_xy(
                 pmhLabel,
                 time,
                 pmh)

 //━━━━━━━━━━━━━━━━━━
// DRAW PML
//━━━━━━━━━━━━━━━━━━

if showPML and not na(pml)

    if na(pmlLine)

        pmlLine := line.new(
             x1 = pmlTime,
             y1 = pml,
             x2 = time,
             y2 = pml,
             xloc = xloc.bar_time,
             extend = extend.right,
             color = pmlColor,
             width = monthLineWidth)

    else

        line.set_xy1(
             pmlLine,
             pmlTime,
             pml)

        line.set_xy2(
             pmlLine,
             time,
             pml)


    if showPMLabels

        if na(pmlLabel)

            pmlLabel := label.new(
                 x = time,
                 y = pml,
                 text = "PML",
                 xloc = xloc.bar_time,
                 style = label.style_label_left,
                 color = pmlLabelColor,
                 textcolor = color.white)

        else

            label.set_xy(
                 pmlLabel,
                 time,
                 pml)   
                 //━━━━━━━━━━━━━━━━━━
// PMH DEBUG
