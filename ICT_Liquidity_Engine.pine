//@version=6
indicator("ICT Liquidity Engine - Base", overlay=true, max_lines_count=50, max_labels_count=50)

//━━━━━━━━━━━━━━━━━━
// GLOBAL TIME ENGINE
//━━━━━━━━━━━━━━━━━━

nyYear = year(time, "America/New_York")
nyMonth = month(time, "America/New_York")
nyDay = dayofmonth(time, "America/New_York")
nyWeek = weekofyear(time, "America/New_York")


dayID = nyYear * 10000 + nyMonth * 100 + nyDay

weekID = nyYear * 100 + nyWeek

monthID = nyYear * 100 + nyMonth


newDay = dayID != dayID[1]

newWeek = weekID != weekID[1]

newMonth = monthID != monthID[1]

//━━━━━━━━━━━━━━━━━━
// PD LEVEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPDH = input.bool(true, "Show PDH")
showPDL = input.bool(true, "Show PDL")


pdhColor = input.color(
     color.green,
     "PDH Color")

pdlColor = input.color(
     color.red,
     "PDL Color")


lineWidth = input.int(
     2,
     "PD Line Width",
     minval = 1,
     maxval = 5)





pwLabelOffset = input.int(
     3,
     "PW Label Offset (bars)",
     minval = 0,
     maxval = 50)


pwLabelGap = input.int(
     8,
     "PW Label Gap (bars)",
     minval = 0,
     maxval = 50)


pwLabelSize = input.string(
     "Tiny",
     "PW Label Size",
     options = ["Tiny", "Small", "Normal"])





//━━━━━━━━━━━━━━━━━━
// PD LABEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPDLabels = input.bool(
     true,
     "Show PDH/PDL Labels")


pdhLabelText = input.string(
     "Previous Day High",
     "PDH Label Text")


pdlLabelText = input.string(
     "Previous Day Low",
     "PDL Label Text")


pdhLabelColor = input.color(
     color.green,
     "PDH Label Color")


pdlLabelColor = input.color(
     color.red,
     "PDL Label Color")


pdLabelOffset = input.int(
     3,
     "PD Label Offset (bars)",
     minval = 0,
     maxval = 50)


pdLabelGap = input.int(
     8,
     "PD Label Gap (bars)",
     minval = 0,
     maxval = 50)


pdLabelSize = input.string(
     "Tiny",
     "PD Label Size",
     options = ["Tiny", "Small", "Normal"])



//━━━━━━━━━━━━━━━━━━
// NY DAY ENGINE
//━━━━━━━━━━━━━━━━━━

var float dayHigh = na
var float dayLow = na

var int dayHighTime = na
var int dayLowTime = na


var float pdh = na
var float pdl = na

var int pdhTime = na
var int pdlTime = na


if na(dayHigh)

    dayHigh := high
    dayLow := low

    dayHighTime := time
    dayLowTime := time


else

    if newDay

        pdh := dayHigh
        pdl := dayLow

        pdhTime := dayHighTime
        pdlTime := dayLowTime


        dayHigh := high
        dayLow := low

        dayHighTime := time
        dayLowTime := time


    else

        if high > dayHigh

            dayHigh := high
            dayHighTime := time


        if low < dayLow

            dayLow := low
            dayLowTime := time
//━━━━━━━━━━━━━━━━━━
// OPEN DAY SETTINGS
//━━━━━━━━━━━━━━━━━━

showOpenDay = input.bool(
     true,
     "Show Open Day")


openDayColor = input.color(
     color.gray,
     "Open Day Color")


openDayLabelColor = input.color(
     color.gray,
     "Open Day Label Color")


openDayWidth = input.int(
     1,
     "Open Day Width",
     minval = 1,
     maxval = 5)


openDayLength = input.int(
     5,
     "Open Day Length (bars)",
     minval = 2,
     maxval = 50)


showOpenDayLabel = input.bool(
     true,
     "Show Open Day Label")


openDayLabelSize = input.string(
     "Tiny",
     "Open Day Label Size",
     options = ["Tiny", "Small", "Normal"])
//━━━━━━━━━━━━━━━━━━
// OPEN DAY ENGINE
//━━━━━━━━━━━━━━━━━━

var float openDay = na
var int openDayTime = na


if na(openDay)

    openDay := open
    openDayTime := time


if newDay

    openDay := open
    openDayTime := time
    
//━━━━━━━━━━━━━━━━━━
// OPEN DAY OBJECTS
//━━━━━━━━━━━━━━━━━━

var line openDayLine = na

var label openDayLabel = na
//━━━━━━━━━━━━━━━━━━
// DRAW OPEN DAY
//━━━━━━━━━━━━━━━━━━

if showOpenDay and not na(openDay)

    lineEndTime = time + (openDayLength * (time - time[1]))


    if na(openDayLine)

        openDayLine := line.new(
             x1 = openDayTime,
             y1 = openDay,
             x2 = lineEndTime,
             y2 = openDay,
             xloc = xloc.bar_time,
             color = openDayColor,
             width = openDayWidth,
             style = line.style_dotted)

    else

        line.set_xy1(
             openDayLine,
             openDayTime,
             openDay)

        line.set_xy2(
             openDayLine,
             lineEndTime,
             openDay)



    if showOpenDayLabel

        if na(openDayLabel)

            openDayLabel := label.new(
                 x = lineEndTime,
                 y = openDay,
                 text = "Open Day",
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 color = na,
                 textcolor = openDayLabelColor,
                 size = openDayLabelSize == "Normal" ? size.normal : openDayLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 openDayLabel,
                 lineEndTime,
                 openDay)

//━━━━━━━━━━━━━━━━━━
// OPEN WEEK SETTINGS
//━━━━━━━━━━━━━━━━━━

showOpenWeek = input.bool(
     true,
     "Show Open Week")


openWeekColor = input.color(
     color.gray,
     "Open Week Color")


openWeekLabelColor = input.color(
     color.gray,
     "Open Week Label Color")


openWeekWidth = input.int(
     1,
     "Open Week Width",
     minval = 1,
     maxval = 5)


openWeekLength = input.int(
     5,
     "Open Week Length (bars)",
     minval = 2,
     maxval = 50)


showOpenWeekLabel = input.bool(
     true,
     "Show Open Week Label")


openWeekLabelSize = input.string(
     "Tiny",
     "Open Week Label Size",
     options = ["Tiny", "Small", "Normal"])



//━━━━━━━━━━━━━━━━━━
// OPEN WEEK ENGINE
//━━━━━━━━━━━━━━━━━━

var float openWeek = na
var int openWeekTime = na


nyWeekDay = dayofweek(
     time,
     "America/New_York")


isMonday = nyWeekDay == dayofweek.monday

wasMonday = nyWeekDay[1] == dayofweek.monday

newOpenWeek = isMonday and not wasMonday


if na(openWeek)

    openWeek := open
    openWeekTime := time


if newOpenWeek

    openWeek := open
    openWeekTime := time



//━━━━━━━━━━━━━━━━━━
// OPEN WEEK VISIBILITY
//━━━━━━━━━━━━━━━━━━

showOpenWeekTF =
     timeframe.in_seconds() <= timeframe.in_seconds("240")

showOpenWeekNow =
     showOpenWeekTF and
     not isMonday



//━━━━━━━━━━━━━━━━━━
// OPEN WEEK OBJECTS
//━━━━━━━━━━━━━━━━━━

var line openWeekLine = na

var label openWeekLabel = na



//━━━━━━━━━━━━━━━━━━
// DRAW OPEN WEEK
//━━━━━━━━━━━━━━━━━━

if showOpenWeekNow and not na(openWeek)

    lineEndTime =
         time +
         (openWeekLength * (time - time[1]))


    if na(openWeekLine)

        openWeekLine := line.new(
             x1 = openWeekTime,
             y1 = openWeek,
             x2 = lineEndTime,
             y2 = openWeek,
             xloc = xloc.bar_time,
             color = openWeekColor,
             width = openWeekWidth,
             style = line.style_dotted)

    else

        line.set_xy1(
             openWeekLine,
             openWeekTime,
             openWeek)

        line.set_xy2(
             openWeekLine,
             lineEndTime,
             openWeek)



    if showOpenWeekLabel

        if na(openWeekLabel)

            openWeekLabel := label.new(
                 x = lineEndTime,
                 y = openWeek,
                 text = "Open Week",
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 color = na,
                 textcolor = openWeekLabelColor,
                 size = openWeekLabelSize == "Normal" ? size.normal : openWeekLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 openWeekLabel,
                 lineEndTime,
                 openWeek)


//━━━━━━━━━━━━━━━━━━
// HIDE OPEN WEEK
//━━━━━━━━━━━━━━━━━━

if not showOpenWeekNow

    if not na(openWeekLine)

        line.delete(openWeekLine)

        openWeekLine := na


    if not na(openWeekLabel)

        label.delete(openWeekLabel)

        openWeekLabel := na

//━━━━━━━━━━━━━━━━━━
// TIMEFRAME VISIBILITY
//━━━━━━━━━━━━━━━━━━

// PDH / PDL → до 4H включительно
showPDLevels = timeframe.in_seconds() <= timeframe.in_seconds("240")

// PWH / PWL → до 3D включительно
showPWLevels = timeframe.in_seconds() <= timeframe.in_seconds("3D")

// PMH / PML → всегда
showPMLevels = true

//━━━━━━━━━━━━━━━━━━
// DRAW PDH / PDL
//━━━━━━━━━━━━━━━━━━

var line pdhLine = na
var line pdlLine = na

var label pdhLabel = na
var label pdlLabel = na


//━━━━━━━━━━━━━━━━━━
// DRAW PDH
//━━━━━━━━━━━━━━━━━━

if showPDH and showPDLevels and not na(pdh)

    pdhLabelX = time + (pdLabelOffset * timeframe.in_seconds() * 1000)

    pdhLineEndX = time + ((pdLabelOffset + pdLabelGap) * timeframe.in_seconds() * 1000)


    if na(pdhLine)

        pdhLine := line.new(
             x1 = pdhTime,
             y1 = pdh,
             x2 = pdhLineEndX,
             y2 = pdh,
             xloc = xloc.bar_time,
             color = pdhColor,
             width = lineWidth)

    else

        line.set_xy1(
             pdhLine,
             pdhTime,
             pdh)

        line.set_xy2(
             pdhLine,
             pdhLineEndX,
             pdh)



    if showPDLabels

        if na(pdhLabel)

            pdhLabel := label.new(
                 x = pdhLineEndX,
                 y = pdh,
                 text = pdhLabelText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pdhLabelColor,
                 textalign = text.align_left,
                 size = pdLabelSize == "Normal" ? size.normal : pdLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pdhLabel,
                 pdhLineEndX,
                 pdh)



//━━━━━━━━━━━━━━━━━━
// DRAW PDL
//━━━━━━━━━━━━━━━━━━

if showPDL and showPDLevels and not na(pdl)

    pdlLabelX = time + (pdLabelOffset * timeframe.in_seconds() * 1000)

    pdlLineEndX = time + ((pdLabelOffset + pdLabelGap) * timeframe.in_seconds() * 1000)


    if na(pdlLine)

        pdlLine := line.new(
             x1 = pdlTime,
             y1 = pdl,
             x2 = pdlLineEndX,
             y2 = pdl,
             xloc = xloc.bar_time,
             color = pdlColor,
             width = lineWidth)

    else

        line.set_xy1(
             pdlLine,
             pdlTime,
             pdl)

        line.set_xy2(
             pdlLine,
             pdlLineEndX,
             pdl)



    if showPDLabels

        if na(pdlLabel)

            pdlLabel := label.new(
                 x = pdlLineEndX,
                 y = pdl,
                 text = pdlLabelText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pdlLabelColor,
                 textalign = text.align_left,
                 size = pdLabelSize == "Normal" ? size.normal : pdLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pdlLabel,
                 pdlLineEndX,
                 pdl)


//━━━━━━━━━━━━━━━━━━
// PW LEVEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPWH = input.bool(true, "Show PWH")
showPWL = input.bool(true, "Show PWL")

pwhColor = input.color(color.yellow, "PWH Color")
pwlColor = input.color(color.purple, "PWL Color")

weekLineWidth = input.int(
     2,
     "Week Line Width",
     minval = 1,
     maxval = 5)


//━━━━━━━━━━━━━━━━━━
// PW LABEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPWLabels = input.bool(
     true,
     "Show PWH/PWL Labels")


pwLabelFormat = input.string(
     "Short",
     "PW Label Format",
     options = ["Short", "Full"])


pwhLabelColor = input.color(
     color.yellow,
     "PWH Label Color")


pwlLabelColor = input.color(
     color.purple,
     "PWL Label Color")






//━━━━━━━━━━━━━━━━━━
// WEEK DATA
//━━━━━━━━━━━━━━━━━━

var float weekHigh = na
var float weekLow = na

var int weekHighTime = na
var int weekLowTime = na


var float pwh = na
var float pwl = na

var int pwhTime = na
var int pwlTime = na



if na(weekHigh)

    weekHigh := high
    weekLow := low

    weekHighTime := time
    weekLowTime := time


else

    if newWeek

        pwh := weekHigh
        pwl := weekLow

        pwhTime := weekHighTime
        pwlTime := weekLowTime


        weekHigh := high
        weekLow := low

        weekHighTime := time
        weekLowTime := time


    else

        if high > weekHigh

            weekHigh := high
            weekHighTime := time


        if low < weekLow

            weekLow := low
            weekLowTime := time


//━━━━━━━━━━━━━━━━━━
// WEEK DRAW OBJECTS
//━━━━━━━━━━━━━━━━━━

var line pwhLine = na
var line pwlLine = na

var label pwhLabel = na
var label pwlLabel = na
//━━━━━━━━━━━━━━━━━━
// DRAW PWH
//━━━━━━━━━━━━━━━━━━

if showPWH and showPWLevels and not na(pwh)

    pwhLabelX = time + (pwLabelOffset * timeframe.in_seconds() * 1000)

    pwhText = pwLabelFormat == "Full" ? "Previous Week High" : "PWH"


    if na(pwhLine)

        pwhLine := line.new(
             x1 = pwhTime,
             y1 = pwh,
             x2 = pwhLabelX,
             y2 = pwh,
             xloc = xloc.bar_time,
             color = pwhColor,
             width = weekLineWidth)

    else

        line.set_xy1(
             pwhLine,
             pwhTime,
             pwh)

        line.set_xy2(
             pwhLine,
             pwhLabelX,
             pwh)


    if showPWLabels

        if na(pwhLabel)

            pwhLabel := label.new(
                 x = pwhLabelX,
                 y = pwh,
                 text = pwhText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pwhLabelColor,
                 textalign = text.align_left,
                 size = pwLabelSize == "Normal" ? size.normal : pwLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pwhLabel,
                 pwhLabelX,
                 pwh)



//━━━━━━━━━━━━━━━━━━
// DRAW PWL
//━━━━━━━━━━━━━━━━━━

if showPWL and showPWLevels and not na(pwl)

    pwlLabelX = time + (pwLabelOffset * timeframe.in_seconds() * 1000)

    pwlText = pwLabelFormat == "Full" ? "Previous Week Low" : "PWL"


    if na(pwlLine)

        pwlLine := line.new(
             x1 = pwlTime,
             y1 = pwl,
             x2 = pwlLabelX,
             y2 = pwl,
             xloc = xloc.bar_time,
             color = pwlColor,
             width = weekLineWidth)

    else

        line.set_xy1(
             pwlLine,
             pwlTime,
             pwl)

        line.set_xy2(
             pwlLine,
             pwlLabelX,
             pwl)


    if showPWLabels

        if na(pwlLabel)

            pwlLabel := label.new(
                 x = pwlLabelX,
                 y = pwl,
                 text = pwlText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pwlLabelColor,
                 textalign = text.align_left,
                 size = pwLabelSize == "Normal" ? size.normal : pwLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pwlLabel,
                 pwlLabelX,
                 pwl)
                 
                
            
  
//━━━━━━━━━━━━━━━━━━
// PM LEVEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPMH = input.bool(true, "Show PMH")
showPML = input.bool(true, "Show PML")

pmhColor = input.color(color.orange, "PMH Color")
pmlColor = input.color(color.blue, "PML Color")

monthLineWidth = input.int(2, "Month Line Width", minval=1, maxval=5)


//━━━━━━━━━━━━━━━━━━
// PM LABEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPMLabels = input.bool(
     true,
     "Show PMH/PML Labels")


pmLabelFormat = input.string(
     "Short",
     "PM Label Format",
     options = ["Short", "Full"])


pmhLabelColor = input.color(
     color.orange,
     "PMH Label Color")


pmlLabelColor = input.color(
     color.blue,
     "PML Label Color")


pmLabelOffset = input.int(
     3,
     "PM Label Offset (bars)",
     minval = 0,
     maxval = 50)


pmLabelSize = input.string(
     "Tiny",
     "PM Label Size",
     options = ["Tiny", "Small", "Normal"])      
    
//━━━━━━━━━━━━━━━━━━
// MONTH ENGINE
//━━━━━━━━━━━━━━━━━━

var float monthHigh = na
var float monthLow = na

var int monthHighTime = na
var int monthLowTime = na


var float pmh = na
var float pml = na

var int pmhTime = na
var int pmlTime = na



if na(monthHigh)

    monthHigh := high
    monthLow := low

    monthHighTime := time
    monthLowTime := time


else

    if newMonth

        pmh := monthHigh
        pml := monthLow

        pmhTime := monthHighTime
        pmlTime := monthLowTime


        monthHigh := high
        monthLow := low

        monthHighTime := time
        monthLowTime := time


    else

        if high > monthHigh

            monthHigh := high
            monthHighTime := time


        if low < monthLow

            monthLow := low
            monthLowTime := time

          
        
    
//━━━━━━━━━━━━━━━━━━
// MONTH DRAW OBJECTS
//━━━━━━━━━━━━━━━━━━

var line pmhLine = na
var line pmlLine = na

var label pmhLabel = na
var label pmlLabel = na

//━━━━━━━━━━━━━━━━━━
// DRAW PMH
//━━━━━━━━━━━━━━━━━━

if showPMH and showPMLevels and not na(pmh)

    pmhLabelX = time + (pmLabelOffset * timeframe.in_seconds() * 1000)

    pmhText = pmLabelFormat == "Full" ? "Previous Month High" : "PMH"


    if na(pmhLine)

        pmhLine := line.new(
             x1 = pmhTime,
             y1 = pmh,
             x2 = pmhLabelX,
             y2 = pmh,
             xloc = xloc.bar_time,
             color = pmhColor,
             width = monthLineWidth)

    else

        line.set_xy1(
             pmhLine,
             pmhTime,
             pmh)

        line.set_xy2(
             pmhLine,
             pmhLabelX,
             pmh)



    if showPMLabels

        if na(pmhLabel)

            pmhLabel := label.new(
                 x = pmhLabelX,
                 y = pmh,
                 text = pmhText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pmhLabelColor,
                 textalign = text.align_left,
                 size = pmLabelSize == "Normal" ? size.normal : pmLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pmhLabel,
                 pmhLabelX,
                 pmh)



//━━━━━━━━━━━━━━━━━━
// DRAW PML
//━━━━━━━━━━━━━━━━━━

if showPML and showPMLevels and not na(pml)

    pmlLabelX = time + (pmLabelOffset * timeframe.in_seconds() * 1000)

    pmlText = pmLabelFormat == "Full" ? "Previous Month Low" : "PML"


    if na(pmlLine)

        pmlLine := line.new(
             x1 = pmlTime,
             y1 = pml,
             x2 = pmlLabelX,
             y2 = pml,
             xloc = xloc.bar_time,
             color = pmlColor,
             width = monthLineWidth)

    else

        line.set_xy1(
             pmlLine,
             pmlTime,
             pml)

        line.set_xy2(
             pmlLine,
             pmlLabelX,
             pml)



    if showPMLabels

        if na(pmlLabel)

            pmlLabel := label.new(
                 x = pmlLabelX,
                 y = pml,
                 text = pmlText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pmlLabelColor,
                 textalign = text.align_left,
                 size = pmLabelSize == "Normal" ? size.normal : pmLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pmlLabel,
                 pmlLabelX,
                 pml)   
                 
            
        
  
