//@version=6
indicator("ICT Liquidity Engine - Base", overlay=true, max_lines_count=50, max_labels_count=50)

//━━━━━━━━━━━━━━━━━━
// GLOBAL TIME ENGINE
//━━━━━━━━━━━━━━━━━━

nyYear = year(time, "America/New_York")
nyMonth = month(time, "America/New_York")
nyDay = dayofmonth(time, "America/New_York")
nyWeek = weekofyear(time, "America/New_York")


dayID = nyYear * 10000 + nyMonth * 100 + nyDay

weekID = nyYear * 100 + nyWeek

monthID = nyYear * 100 + nyMonth


newDay = dayID != dayID[1]

newWeek = weekID != weekID[1]

newMonth = monthID != monthID[1]

//━━━━━━━━━━━━━━━━━━
// LIQUIDITY LEVELS SETTINGS
//━━━━━━━━━━━━━━━━━━

//━━━━━━━━━━━━━━━━━━
// PDH / PDL
//━━━━━━━━━━━━━━━━━━

showPDH = input.bool(
     true,
     "PDH",
     group = "LIQUIDITY LEVELS")


pdhColor = input.color(
     color.green,
     "PDH Color",
     group = "LIQUIDITY LEVELS")


showPDL = input.bool(
     true,
     "PDL",
     group = "LIQUIDITY LEVELS")


pdlColor = input.color(
     color.red,
     "PDL Color",
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// PWH / PWL
//━━━━━━━━━━━━━━━━━━

showPWH = input.bool(
     true,
     "PWH",
     group = "LIQUIDITY LEVELS")


pwhColor = input.color(
     color.yellow,
     "PWH Color",
     group = "LIQUIDITY LEVELS")


showPWL = input.bool(
     true,
     "PWL",
     group = "LIQUIDITY LEVELS")


pwlColor = input.color(
     color.purple,
     "PWL Color",
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// PMH / PML
//━━━━━━━━━━━━━━━━━━

showPMH = input.bool(
     true,
     "PMH",
     group = "LIQUIDITY LEVELS")


pmhColor = input.color(
     color.orange,
     "PMH Color",
     group = "LIQUIDITY LEVELS")


showPML = input.bool(
     true,
     "PML",
     group = "LIQUIDITY LEVELS")


pmlColor = input.color(
     color.blue,
     "PML Color",
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// GENERAL LIQUIDITY SETTINGS
//━━━━━━━━━━━━━━━━━━

lineWidth = input.int(
     2,
     "PD Line Width",
     minval = 1,
     maxval = 5,
     group = "LIQUIDITY LEVELS")


weekLineWidth = input.int(
     2,
     "PW Line Width",
     minval = 1,
     maxval = 5,
     group = "LIQUIDITY LEVELS")


monthLineWidth = input.int(
     2,
     "PM Line Width",
     minval = 1,
     maxval = 5,
     group = "LIQUIDITY LEVELS")

//━━━━━━━━━━━━━━━━━━
// SWEPT LABEL COLOR
//━━━━━━━━━━━━━━━━━━

sweptLabelColor = input.color(
     color.white,
     "Swept Label Color",
     group = "LIQUIDITY LEVELS")    

sweepXOffset = input.int(
     1,
     "Sweep X Offset (bars)",
     minval = 0,
     maxval = 10,
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// LABEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPDLabels = input.bool(
     true,
     "Show PDH/PDL Labels",
     group = "LIQUIDITY LEVELS")


pdhLabelText = input.string(
     "Previous Day High",
     "PDH Label Text",
     group = "LIQUIDITY LEVELS")


pdlLabelText = input.string(
     "Previous Day Low",
     "PDL Label Text",
     group = "LIQUIDITY LEVELS")


pdhLabelColor = input.color(
     color.green,
     "PDH Label Color",
     group = "LIQUIDITY LEVELS")


pdlLabelColor = input.color(
     color.red,
     "PDL Label Color",
     group = "LIQUIDITY LEVELS")


pdLabelOffset = input.int(
     3,
     "PD Label Offset (bars)",
     minval = 0,
     maxval = 50,
     group = "LIQUIDITY LEVELS")


pdLabelGap = input.int(
     8,
     "PD Label Gap (bars)",
     minval = 0,
     maxval = 50,
     group = "LIQUIDITY LEVELS")


pdLabelSize = input.string(
     "Tiny",
     "PD Label Size",
     options = ["Tiny", "Small", "Normal"],
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// PW LABEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPWLabels = input.bool(
     true,
     "Show PWH/PWL Labels",
     group = "LIQUIDITY LEVELS")


pwLabelFormat = input.string(
     "Short",
     "PW Label Format",
     options = ["Short", "Full"],
     group = "LIQUIDITY LEVELS")


pwhLabelColor = input.color(
     color.yellow,
     "PWH Label Color",
     group = "LIQUIDITY LEVELS")


pwlLabelColor = input.color(
     color.purple,
     "PWL Label Color",
     group = "LIQUIDITY LEVELS")


pwLabelOffset = input.int(
     3,
     "PW Label Offset (bars)",
     minval = 0,
     maxval = 50,
     group = "LIQUIDITY LEVELS")


pwLabelGap = input.int(
     8,
     "PW Label Gap (bars)",
     minval = 0,
     maxval = 50,
     group = "LIQUIDITY LEVELS")


pwLabelSize = input.string(
     "Tiny",
     "PW Label Size",
     options = ["Tiny", "Small", "Normal"],
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// PM LABEL SETTINGS
//━━━━━━━━━━━━━━━━━━

showPMLabels = input.bool(
     true,
     "Show PMH/PML Labels",
     group = "LIQUIDITY LEVELS")


pmLabelFormat = input.string(
     "Short",
     "PM Label Format",
     options = ["Short", "Full"],
     group = "LIQUIDITY LEVELS")


pmhLabelColor = input.color(
     color.orange,
     "PMH Label Color",
     group = "LIQUIDITY LEVELS")


pmlLabelColor = input.color(
     color.blue,
     "PML Label Color",
     group = "LIQUIDITY LEVELS")


pmLabelOffset = input.int(
     3,
     "PM Label Offset (bars)",
     minval = 0,
     maxval = 50,
     group = "LIQUIDITY LEVELS")


pmLabelSize = input.string(
    "Tiny",
     "PM Label Size",
     options = ["Tiny", "Small", "Normal"],
     group = "LIQUIDITY LEVELS")



//━━━━━━━━━━━━━━━━━━
// NY DAY ENGINE
//━━━━━━━━━━━━━━━━━━

var float dayHigh = na
var float dayLow = na

var int dayHighTime = na
var int dayLowTime = na


var float pdh = na
var float pdl = na

var int pdhTime = na
var int pdlTime = na


if na(dayHigh)

    dayHigh := high
    dayLow := low

    dayHighTime := time
    dayLowTime := time


else

    if newDay

        pdh := dayHigh
        pdl := dayLow

        pdhTime := dayHighTime
        pdlTime := dayLowTime


        dayHigh := high
        dayLow := low

        dayHighTime := time
        dayLowTime := time


    else

        if high > dayHigh

            dayHigh := high
            dayHighTime := time


        if low < dayLow

            dayLow := low
            dayLowTime := time

        
    
//━━━━━━━━━━━━━━━━━━
// TIME LEVELS SETTINGS
//━━━━━━━━━━━━━━━━━━

show0830 = input.bool(
     true,
     "Show 08:30 NY")


show0930 = input.bool(
     true,
     "Show 09:30 NY")


time0830Color = input.color(
     color.gray,
     "08:30 NY Color")


time0930Color = input.color(
     color.gray,
     "09:30 NY Color")


time0830LabelColor = input.color(
     color.gray,
     "08:30 NY Label Color")


time0930LabelColor = input.color(
     color.gray,
     "09:30 NY Label Color")


timeLevelWidth = input.int(
     1,
     "Time Level Width",
     minval = 1,
     maxval = 5)


showTimeLevelLabels = input.bool(
     true,
     "Show Time Level Labels")


timeLevelLabelSize = input.string(
     "Tiny",
     "Time Level Label Size",
     options = ["Tiny", "Small", "Normal"])



//━━━━━━━━━━━━━━━━━━
// TIME LEVELS ENGINE
//━━━━━━━━━━━━━━━━━━

var float open0830 = na
var float open0930 = na

var int open0830Time = na
var int open0930Time = na


nyHour = hour(
     time,
     "America/New_York")


nyMinute = minute(
     time,
     "America/New_York")


is0830 = nyHour == 8 and nyMinute == 30

is0930 = nyHour == 9 and nyMinute == 30



//━━━━━━━━━━━━━━━━━━
// RESET AT NEW NY DAY
//━━━━━━━━━━━━━━━━━━

if newDay

    open0830 := na
    open0930 := na

    open0830Time := na
    open0930Time := na



//━━━━━━━━━━━━━━━━━━
// CAPTURE 08:30 OPEN
//━━━━━━━━━━━━━━━━━━

if is0830

    open0830 := open
    open0830Time := time



//━━━━━━━━━━━━━━━━━━
// CAPTURE 09:30 OPEN
//━━━━━━━━━━━━━━━━━━

if is0930

    open0930 := open
    open0930Time := time



//━━━━━━━━━━━━━━━━━━
// TIMEFRAME VISIBILITY
//━━━━━━━━━━━━━━━━━━

showTimeLevelsTF =
     timeframe.in_seconds() <= timeframe.in_seconds("240")



//━━━━━━━━━━━━━━━━━━
// TIME LEVEL OBJECTS
//━━━━━━━━━━━━━━━━━━

var line open0830Line = na
var line open0930Line = na

var label open0830Label = na
var label open0930Label = na


//━━━━━━━━━━━━━━━━━━
// DELETE OLD TIME LEVELS AT NEW NY DAY
//━━━━━━━━━━━━━━━━━━

if newDay

    if not na(open0830Line)

        line.delete(open0830Line)

        open0830Line := na


    if not na(open0930Line)

        line.delete(open0930Line)

        open0930Line := na


    if not na(open0830Label)

        label.delete(open0830Label)

        open0830Label := na


    if not na(open0930Label)

        label.delete(open0930Label)

        open0930Label := na



//━━━━━━━━━━━━━━━━━━
// DRAW 08:30 NY
//━━━━━━━━━━━━━━━━━━

if show0830 and showTimeLevelsTF and not na(open0830)

    if na(open0830Line)

        open0830Line := line.new(
             x1 = open0830Time,
             y1 = open0830,
             x2 = time,
             y2 = open0830,
             xloc = xloc.bar_time,
             color = time0830Color,
             width = timeLevelWidth,
             style = line.style_dotted)

    else

        line.set_xy1(
             open0830Line,
             open0830Time,
             open0830)

        line.set_xy2(
             open0830Line,
             time,
             open0830)



    if showTimeLevelLabels

        if na(open0830Label)

            open0830Label := label.new(
                 x = time,
                 y = open0830,
                 text = "08:30",
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 color = na,
                 textcolor = time0830LabelColor,
                 size = timeLevelLabelSize == "Normal" ? size.normal : timeLevelLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 open0830Label,
                 time,
                 open0830)

                
            
        
    
//━━━━━━━━━━━━━━━━━━
// DRAW 09:30 NY
//━━━━━━━━━━━━━━━━━━

if show0930 and showTimeLevelsTF and not na(open0930)

    if na(open0930Line)

        open0930Line := line.new(
             x1 = open0930Time,
             y1 = open0930,
             x2 = time,
             y2 = open0930,
             xloc = xloc.bar_time,
             color = time0930Color,
             width = timeLevelWidth,
             style = line.style_dotted)

    else

        line.set_xy1(
             open0930Line,
             open0930Time,
             open0930)

        line.set_xy2(
             open0930Line,
             time,
             open0930)



    if showTimeLevelLabels

        if na(open0930Label)

            open0930Label := label.new(
                 x = time,
                 y = open0930,
                 text = "09:30",
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 color = na,
                 textcolor = time0930LabelColor,
                 size = timeLevelLabelSize == "Normal" ? size.normal : timeLevelLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 open0930Label,
                 time,
                 open0930)



//━━━━━━━━━━━━━━━━━━
// HIDE TIME LEVELS
//━━━━━━━━━━━━━━━━━━

if not showTimeLevelsTF

    if not na(open0830Line)

        line.delete(open0830Line)

        open0830Line := na


    if not na(open0930Line)

        line.delete(open0930Line)

        open0930Line := na


    if not na(open0830Label)

        label.delete(open0830Label)

        open0830Label := na


    if not na(open0930Label)

        label.delete(open0930Label)

        open0930Label := na
//━━━━━━━━━━━━━━━━━━
// OPEN LEVELS SETTINGS
//━━━━━━━━━━━━━━━━━━

//━━━━━━━━━━━━━━━━━━
// OPEN DAY
//━━━━━━━━━━━━━━━━━━

showOpenDay = input.bool(
     true,
     "Open Day",
     group = "OPEN LEVELS")


openDayColor = input.color(
     color.gray,
     "Open Day Color",
     group = "OPEN LEVELS")


openDayLabelColor = input.color(
     color.gray,
     "Open Day Label Color",
     group = "OPEN LEVELS")


openDayWidth = input.int(
     1,
     "Open Day Width",
     minval = 1,
     maxval = 5,
     group = "OPEN LEVELS")


openDayLength = input.int(
     5,
     "Open Day Length (bars)",
     minval = 2,
     maxval = 50,
     group = "OPEN LEVELS")


showOpenDayLabel = input.bool(
     true,
     "Show Open Day Label",
     group = "OPEN LEVELS")


openDayLabelSize = input.string(
     "Tiny",
     "Open Day Label Size",
     options = ["Tiny", "Small", "Normal"],
     group = "OPEN LEVELS")



//━━━━━━━━━━━━━━━━━━
// OPEN WEEK
//━━━━━━━━━━━━━━━━━━

showOpenWeek = input.bool(
     true,
     "Open Week",
     group = "OPEN LEVELS")


openWeekColor = input.color(
     color.gray,
     "Open Week Color",
     group = "OPEN LEVELS")


openWeekLabelColor = input.color(
     color.gray,
     "Open Week Label Color",
     group = "OPEN LEVELS")


openWeekWidth = input.int(
     1,
     "Open Week Width",
     minval = 1,
     maxval = 5,
     group = "OPEN LEVELS")


openWeekLength = input.int(
     5,
     "Open Week Length (bars)",
     minval = 2,
     maxval = 50,
     group = "OPEN LEVELS")


showOpenWeekLabel = input.bool(
     true,
     "Show Open Week Label",
     group = "OPEN LEVELS")


openWeekLabelSize = input.string(
     "Tiny",
     "Open Week Label Size",
     options = ["Tiny", "Small", "Normal"],
     group = "OPEN LEVELS")
//━━━━━━━━━━━━━━━━━━
// OPEN DAY ENGINE
//━━━━━━━━━━━━━━━━━━

var float openDay = na
var int openDayTime = na


if na(openDay)

    openDay := open
    openDayTime := time


if newDay

    openDay := open
    openDayTime := time
    
//━━━━━━━━━━━━━━━━━━
// OPEN DAY OBJECTS
//━━━━━━━━━━━━━━━━━━

var line openDayLine = na

var label openDayLabel = na
//━━━━━━━━━━━━━━━━━━
// DRAW OPEN DAY
//━━━━━━━━━━━━━━━━━━

if showOpenDay and not na(openDay)

    lineEndTime = time + (openDayLength * (time - time[1]))


    if na(openDayLine)

        openDayLine := line.new(
             x1 = openDayTime,
             y1 = openDay,
             x2 = lineEndTime,
             y2 = openDay,
             xloc = xloc.bar_time,
             color = openDayColor,
             width = openDayWidth,
             style = line.style_dotted)

    else

        line.set_xy1(
             openDayLine,
             openDayTime,
             openDay)

        line.set_xy2(
             openDayLine,
             lineEndTime,
             openDay)



    if showOpenDayLabel

        if na(openDayLabel)

            openDayLabel := label.new(
                 x = lineEndTime,
                 y = openDay,
                 text = "Open Day",
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 color = na,
                 textcolor = openDayLabelColor,
                 size = openDayLabelSize == "Normal" ? size.normal : openDayLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 openDayLabel,
                 lineEndTime,
                 openDay)
//━━━━━━━━━━━━━━━━━━
// OPEN WEEK ENGINE
//━━━━━━━━━━━━━━━━━━

var float openWeek = na
var int openWeekTime = na


nyWeekDay = dayofweek(
     time,
     "America/New_York")


isMonday = nyWeekDay == dayofweek.monday

wasMonday = nyWeekDay[1] == dayofweek.monday

newOpenWeek = isMonday and not wasMonday


if na(openWeek)

    openWeek := open
    openWeekTime := time


if newOpenWeek

    openWeek := open
    openWeekTime := time



//━━━━━━━━━━━━━━━━━━
// OPEN WEEK VISIBILITY
//━━━━━━━━━━━━━━━━━━

showOpenWeekTF =
     timeframe.in_seconds() <= timeframe.in_seconds("240")

showOpenWeekNow =
     showOpenWeekTF and
     not isMonday



//━━━━━━━━━━━━━━━━━━
// OPEN WEEK OBJECTS
//━━━━━━━━━━━━━━━━━━

var line openWeekLine = na

var label openWeekLabel = na



//━━━━━━━━━━━━━━━━━━
// DRAW OPEN WEEK
//━━━━━━━━━━━━━━━━━━

if showOpenWeekNow and not na(openWeek)

    lineEndTime =
         time +
         (openWeekLength * (time - time[1]))


    if na(openWeekLine)

        openWeekLine := line.new(
             x1 = openWeekTime,
             y1 = openWeek,
             x2 = lineEndTime,
             y2 = openWeek,
             xloc = xloc.bar_time,
             color = openWeekColor,
             width = openWeekWidth,
             style = line.style_dotted)

    else

        line.set_xy1(
             openWeekLine,
             openWeekTime,
             openWeek)

        line.set_xy2(
             openWeekLine,
             lineEndTime,
             openWeek)



    if showOpenWeekLabel

        if na(openWeekLabel)

            openWeekLabel := label.new(
                 x = lineEndTime,
                 y = openWeek,
                 text = "Open Week",
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 color = na,
                 textcolor = openWeekLabelColor,
                 size = openWeekLabelSize == "Normal" ? size.normal : openWeekLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 openWeekLabel,
                 lineEndTime,
                 openWeek)


//━━━━━━━━━━━━━━━━━━
// HIDE OPEN WEEK
//━━━━━━━━━━━━━━━━━━

if not showOpenWeekNow

    if not na(openWeekLine)

        line.delete(openWeekLine)

        openWeekLine := na


    if not na(openWeekLabel)

        label.delete(openWeekLabel)

        openWeekLabel := na

//━━━━━━━━━━━━━━━━━━
// TIMEFRAME VISIBILITY
//━━━━━━━━━━━━━━━━━━

// PDH / PDL → до 4H включительно
showPDLevels = timeframe.in_seconds() <= timeframe.in_seconds("240")

// PWH / PWL → до 3D включительно
showPWLevels = timeframe.in_seconds() <= timeframe.in_seconds("3D")

// PMH / PML → всегда
showPMLevels = true

//━━━━━━━━━━━━━━━━━━
// DRAW PDH / PDL
//━━━━━━━━━━━━━━━━━━

var line pdhLine = na
var line pdlLine = na

var label pdhLabel = na
var label pdlLabel = na


//━━━━━━━━━━━━━━━━━━
// PDH / PDL SWEEP ENGINE
//━━━━━━━━━━━━━━━━━━

var bool pdhSwept = false
var bool pdlSwept = false

var int pdhSweepTime = na
var int pdlSweepTime = na

var label pdhSweptLabel = na
var label pdlSweptLabel = na


//━━━━━━━━━━━━━━━━━━
// RESET SWEEP STATUS AT NEW DAY
//━━━━━━━━━━━━━━━━━━

if newDay

    pdhSwept := false
    pdlSwept := false

    pdhSweepTime := na
    pdlSweepTime := na

    if not na(pdhSweptLabel)
        label.delete(pdhSweptLabel)
        pdhSweptLabel := na

    if not na(pdlSweptLabel)
        label.delete(pdlSweptLabel)
        pdlSweptLabel := na


//━━━━━━━━━━━━━━━━━━
// DETECT PDH SWEEP
//━━━━━━━━━━━━━━━━━━

if not pdhSwept and not na(pdh)

    if high >= pdh

        pdhSwept := true
        pdhSweepTime := time


//━━━━━━━━━━━━━━━━━━
// DETECT PDL SWEEP
//━━━━━━━━━━━━━━━━━━

if not pdlSwept and not na(pdl)

    if low <= pdl

        pdlSwept := true
        pdlSweepTime := time


//━━━━━━━━━━━━━━━━━━
// DRAW PDH
//━━━━━━━━━━━━━━━━━━

if showPDH and showPDLevels and not na(pdh)

    pdhLineEndX = pdhSwept and not na(pdhSweepTime) ? pdhSweepTime : time + ((pdLabelOffset + pdLabelGap) * timeframe.in_seconds() * 1000)

    pdhSweepX = pdhSwept and not na(pdhSweepTime) ? pdhSweepTime + (sweepXOffset * timeframe.in_seconds() * 1000) : na


    if na(pdhLine)

        pdhLine := line.new(
             x1 = pdhTime,
             y1 = pdh,
             x2 = pdhLineEndX,
             y2 = pdh,
             xloc = xloc.bar_time,
             color = pdhSwept ? color.new(pdhColor, 60) : pdhColor,
             width = lineWidth,
             style = pdhSwept ? line.style_dotted : line.style_solid)

    else

        line.set_xy1(
             pdhLine,
             pdhTime,
             pdh)

        line.set_xy2(
             pdhLine,
             pdhLineEndX,
             pdh)

        line.set_color(
             pdhLine,
             pdhSwept ? color.new(pdhColor, 60) : pdhColor)

        line.set_style(
             pdhLine,
             pdhSwept ? line.style_dotted : line.style_solid)



    //━━━━━━━━━━━━━━━━━━
    // ACTIVE PDH LABEL
    //━━━━━━━━━━━━━━━━━━

    if showPDLabels and not pdhSwept

        if na(pdhLabel)

            pdhLabel := label.new(
                 x = pdhLineEndX,
                 y = pdh,
                 text = pdhLabelText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pdhLabelColor,
                 textalign = text.align_left,
                 size = pdLabelSize == "Normal" ? size.normal : pdLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pdhLabel,
                 pdhLineEndX,
                 pdh)


    
//━━━━━━━━━━━━━━━━━━
// SWEPT PDH LABEL
//━━━━━━━━━━━━━━━━━━

if pdhSwept and not na(pdhSweepTime)

    if not na(pdhLabel)

        label.delete(pdhLabel)
        pdhLabel := na


    if na(pdhSweptLabel)

        pdhSweptLabel := label.new(
             x = pdhSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             y = pdh,
             text = "PDH X",
             xloc = xloc.bar_time,
             style = label.style_none,
             textcolor = sweptLabelColor,
             textalign = text.align_left,
             size = size.normal)

    else

        label.set_xy(
             pdhSweptLabel,
             pdhSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             pdh)


//━━━━━━━━━━━━━━━━━━
// DRAW PDL
//━━━━━━━━━━━━━━━━━━

if showPDL and showPDLevels and not na(pdl)

    pdlLineEndX = pdlSwept and not na(pdlSweepTime) ? pdlSweepTime : time + ((pdLabelOffset + pdLabelGap) * timeframe.in_seconds() * 1000)

    pdlSweepX = pdlSwept and not na(pdlSweepTime) ? pdlSweepTime + (sweepXOffset * timeframe.in_seconds() * 1000) : na


    if na(pdlLine)

        pdlLine := line.new(
             x1 = pdlTime,
             y1 = pdl,
             x2 = pdlLineEndX,
             y2 = pdl,
             xloc = xloc.bar_time,
             color = pdlSwept ? color.new(pdlColor, 60) : pdlColor,
width = lineWidth,
             style = pdlSwept ? line.style_dotted : line.style_solid)

    else

        line.set_xy1(
             pdlLine,
             pdlTime,
             pdl)

        line.set_xy2(
             pdlLine,
             pdlLineEndX,
             pdl)

        line.set_color(
             pdlLine,
             pdlSwept ? color.new(pdlColor, 60) : pdlColor)

        line.set_style(
             pdlLine,
             pdlSwept ? line.style_dotted : line.style_solid)



    //━━━━━━━━━━━━━━━━━━
    // ACTIVE PDL LABEL
    //━━━━━━━━━━━━━━━━━━

    if showPDLabels and not pdlSwept

        if na(pdlLabel)

            pdlLabel := label.new(
                 x = pdlLineEndX,
                 y = pdl,
                 text = pdlLabelText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pdlLabelColor,
                 textalign = text.align_left,
                 size = pdLabelSize == "Normal" ? size.normal : pdLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pdlLabel,
                 pdlLineEndX,
                 pdl)


    //━━━━━━━━━━━━━━━━━━
// SWEPT PDL LABEL
//━━━━━━━━━━━━━━━━━━

if pdlSwept and not na(pdlSweepTime)

    if not na(pdlLabel)

        label.delete(pdlLabel)
        pdlLabel := na


    if na(pdlSweptLabel)

        pdlSweptLabel := label.new(
             x = pdlSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             y = pdl,
             text = "PDL X",
             xloc = xloc.bar_time,
             style = label.style_none,
             textcolor = sweptLabelColor,
             textalign = text.align_left,
             size = size.normal)

    else

        label.set_xy(
             pdlSweptLabel,
             pdlSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             pdl)

                

//━━━━━━━━━━━━━━━━━━
// WEEK DATA
//━━━━━━━━━━━━━━━━━━

var float weekHigh = na
var float weekLow = na

var int weekHighTime = na
var int weekLowTime = na


var float pwh = na
var float pwl = na

var int pwhTime = na
var int pwlTime = na


//━━━━━━━━━━━━━━━━━━
// PWH / PWL SWEEP STATE
//━━━━━━━━━━━━━━━━━━

var bool pwhSwept = false
var bool pwlSwept = false

var int pwhSweepTime = na
var int pwlSweepTime = na

var label pwhSweptLabel = na
var label pwlSweptLabel = na



//━━━━━━━━━━━━━━━━━━
// BUILD CURRENT WEEK HIGH / LOW
//━━━━━━━━━━━━━━━━━━

if na(weekHigh)

    weekHigh := high
    weekLow := low

    weekHighTime := time
    weekLowTime := time


else

    if newWeek

        // Previous week becomes final PWH / PWL

        pwh := weekHigh
        pwl := weekLow

        pwhTime := weekHighTime
        pwlTime := weekLowTime


        // Reset sweep state for new previous-week levels

        pwhSwept := false
        pwlSwept := false

        pwhSweepTime := na
        pwlSweepTime := na


        if not na(pwhSweptLabel)

            label.delete(pwhSweptLabel)
            pwhSweptLabel := na


        if not na(pwlSweptLabel)

            label.delete(pwlSweptLabel)
            pwlSweptLabel := na


        // Start tracking new current week

        weekHigh := high
        weekLow := low

        weekHighTime := time
        weekLowTime := time


    else

        if high > weekHigh

            weekHigh := high
            weekHighTime := time


        if low < weekLow

            weekLow := low
            weekLowTime := time



//━━━━━━━━━━━━━━━━━━
// DETECT PWH SWEEP
//━━━━━━━━━━━━━━━━━━

if not pwhSwept and not na(pwh)

    if high >= pwh

        pwhSwept := true
        pwhSweepTime := time



//━━━━━━━━━━━━━━━━━━
// DETECT PWL SWEEP
//━━━━━━━━━━━━━━━━━━

if not pwlSwept and not na(pwl)

    if low <= pwl

        pwlSwept := true
        pwlSweepTime := time



//━━━━━━━━━━━━━━━━━━
// WEEK DRAW OBJECTS
//━━━━━━━━━━━━━━━━━━

var line pwhLine = na
var line pwlLine = na

var label pwhLabel = na
var label pwlLabel = na



//━━━━━━━━━━━━━━━━━━
// DRAW PWH
//━━━━━━━━━━━━━━━━━━

if showPWH and showPWLevels and not na(pwh)

    pwhLabelX = pwhSwept and not na(pwhSweepTime) ? pwhSweepTime + (sweepXOffset * timeframe.in_seconds() * 1000) : time + (pwLabelOffset * timeframe.in_seconds() * 1000)

    pwhLineEndX = pwhSwept and not na(pwhSweepTime) ? pwhSweepTime : time + (pwLabelOffset * timeframe.in_seconds() * 1000)

    pwhText = pwLabelFormat == "Full" ? "Previous Week High" : "PWH"



    if na(pwhLine)

        pwhLine := line.new(
             x1 = pwhTime,
             y1 = pwh,
             x2 = pwhLineEndX,
             y2 = pwh,
             xloc = xloc.bar_time,
             color = pwhSwept ? color.new(pwhColor, 60) : pwhColor,
             width = weekLineWidth,
             style = pwhSwept ? line.style_dotted : line.style_solid)

    else

        line.set_xy1(
             pwhLine,
             pwhTime,
             pwh)

        line.set_xy2(
             pwhLine,
             pwhLineEndX,
             pwh)

        line.set_color(
             pwhLine,
             pwhSwept ? color.new(pwhColor, 60) : pwhColor)

        line.set_style(
             pwhLine,
             pwhSwept ? line.style_dotted : line.style_solid)



    //━━━━━━━━━━━━━━━━━━
    // ACTIVE PWH LABEL
    //━━━━━━━━━━━━━━━━━━

    if showPWLabels and not pwhSwept

        if na(pwhLabel)

            pwhLabel := label.new(
                 x = pwhLabelX,
                 y = pwh,
                 text = pwhText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pwhLabelColor,
                 textalign = text.align_left,
                 size = pwLabelSize == "Normal" ? size.normal : pwLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pwhLabel,
                 pwhLabelX,
                 pwh)



   
//━━━━━━━━━━━━━━━━━━
// SWEPT PWH LABEL
//━━━━━━━━━━━━━━━━━━

if pwhSwept and not na(pwhSweepTime)

    if not na(pwhLabel)

        label.delete(pwhLabel)
        pwhLabel := na


    if na(pwhSweptLabel)

        pwhSweptLabel := label.new(
             x = pwhSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             y = pwh,
             text = "PWH X",
             xloc = xloc.bar_time,
             style = label.style_none,
             textcolor = sweptLabelColor,
             textalign = text.align_left,
             size = size.normal)

    else

        label.set_xy(
             pwhSweptLabel,
             pwhSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             pwh)


//━━━━━━━━━━━━━━━━━━
// DRAW PWL
//━━━━━━━━━━━━━━━━━━

if showPWL and showPWLevels and not na(pwl)

    pwlLabelX = pwlSwept and not na(pwlSweepTime) ? pwlSweepTime + (sweepXOffset * timeframe.in_seconds() * 1000) : time + (pwLabelOffset * timeframe.in_seconds() * 1000)

    pwlLineEndX = pwlSwept and not na(pwlSweepTime) ? pwlSweepTime : time + (pwLabelOffset * timeframe.in_seconds() * 1000)

    pwlText = pwLabelFormat == "Full" ? "Previous Week Low" : "PWL"



    if na(pwlLine)

        pwlLine := line.new(
             x1 = pwlTime,
             y1 = pwl,
             x2 = pwlLineEndX,
             y2 = pwl,
             xloc = xloc.bar_time,
             color = pwlSwept ? color.new(pwlColor, 60) : pwlColor,
             width = weekLineWidth,
             style = pwlSwept ? line.style_dotted : line.style_solid)

    else

        line.set_xy1(
             pwlLine,
             pwlTime,
             pwl)

        line.set_xy2(
             pwlLine,
             pwlLineEndX,
             pwl)

        line.set_color(
             pwlLine,
             pwlSwept ? color.new(pwlColor, 60) : pwlColor)

        line.set_style(
             pwlLine,
             pwlSwept ? line.style_dotted : line.style_solid)



    //━━━━━━━━━━━━━━━━━━
    // ACTIVE PWL LABEL
    //━━━━━━━━━━━━━━━━━━

    if showPWLabels and not pwlSwept

        if na(pwlLabel)

            pwlLabel := label.new(
                 x = pwlLabelX,
                 y = pwl,
                 text = pwlText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pwlLabelColor,
                 textalign = text.align_left,
                 size = pwLabelSize == "Normal" ? size.normal : pwLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pwlLabel,
                 pwlLabelX,
                 pwl)


    
//━━━━━━━━━━━━━━━━━━
// SWEPT PWL LABEL
//━━━━━━━━━━━━━━━━━━

if pwlSwept and not na(pwlSweepTime)

    if not na(pwlLabel)

        label.delete(pwlLabel)
        pwlLabel := na


    if na(pwlSweptLabel)

        pwlSweptLabel := label.new(
             x = pwlSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             y = pwl,
             text = "PWL X",
             xloc = xloc.bar_time,
             style = label.style_none,
             textcolor = sweptLabelColor,
             textalign = text.align_left,
             size = size.normal)

    else

        label.set_xy(
             pwlSweptLabel,
             pwlSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             pwl)
                       
//━━━━━━━━━━━━━━━━━━
// MONTH ENGINE
//━━━━━━━━━━━━━━━━━━

var float monthHigh = na
var float monthLow = na

var int monthHighTime = na
var int monthLowTime = na


var float pmh = na
var float pml = na

var int pmhTime = na
var int pmlTime = na



//━━━━━━━━━━━━━━━━━━
// PMH / PML SWEEP STATE
//━━━━━━━━━━━━━━━━━━

var bool pmhSwept = false
var bool pmlSwept = false

var int pmhSweepTime = na
var int pmlSweepTime = na

var label pmhSweptLabel = na
var label pmlSweptLabel = na



//━━━━━━━━━━━━━━━━━━
// BUILD CURRENT MONTH HIGH / LOW
//━━━━━━━━━━━━━━━━━━

if na(monthHigh)

    monthHigh := high
    monthLow := low

    monthHighTime := time
    monthLowTime := time


else

    if newMonth

        // Previous month becomes final PMH / PML

        pmh := monthHigh
        pml := monthLow

        pmhTime := monthHighTime
        pmlTime := monthLowTime


        // Reset sweep state for new previous-month levels

        pmhSwept := false
        pmlSwept := false

        pmhSweepTime := na
        pmlSweepTime := na


        if not na(pmhSweptLabel)

            label.delete(pmhSweptLabel)
            pmhSweptLabel := na


        if not na(pmlSweptLabel)

            label.delete(pmlSweptLabel)
            pmlSweptLabel := na


        // Start tracking new current month

        monthHigh := high
        monthLow := low

        monthHighTime := time
        monthLowTime := time


    else

        if high > monthHigh

            monthHigh := high
            monthHighTime := time


        if low < monthLow

            monthLow := low
            monthLowTime := time



//━━━━━━━━━━━━━━━━━━
// DETECT PMH SWEEP
//━━━━━━━━━━━━━━━━━━

if not pmhSwept and not na(pmh)

    if high >= pmh

        pmhSwept := true
        pmhSweepTime := time



//━━━━━━━━━━━━━━━━━━
// DETECT PML SWEEP
//━━━━━━━━━━━━━━━━━━

if not pmlSwept and not na(pml)

    if low <= pml

        pmlSwept := true
        pmlSweepTime := time



//━━━━━━━━━━━━━━━━━━
// MONTH DRAW OBJECTS
//━━━━━━━━━━━━━━━━━━

var line pmhLine = na
var line pmlLine = na

var label pmhLabel = na
var label pmlLabel = na



//━━━━━━━━━━━━━━━━━━
// DRAW PMH
//━━━━━━━━━━━━━━━━━━

if showPMH and showPMLevels and not na(pmh)

    pmhLineEndX = pmhSwept and not na(pmhSweepTime) ? pmhSweepTime : time + (pmLabelOffset * timeframe.in_seconds() * 1000)

    pmhText = pmLabelFormat == "Full" ? "Previous Month High" : "PMH"



    if na(pmhLine)

        pmhLine := line.new(
             x1 = pmhTime,
             y1 = pmh,
             x2 = pmhLineEndX,
             y2 = pmh,
             xloc = xloc.bar_time,
             color = pmhSwept ? color.new(pmhColor, 60) : pmhColor,
             width = monthLineWidth,
             style = pmhSwept ? line.style_dotted : line.style_solid)

    else

        line.set_xy1(
             pmhLine,
             pmhTime,
             pmh)

        line.set_xy2(
             pmhLine,
             pmhLineEndX,
             pmh)

        line.set_color(
             pmhLine,
             pmhSwept ? color.new(pmhColor, 60) : pmhColor)

        line.set_style(
             pmhLine,
             pmhSwept ? line.style_dotted : line.style_solid)



    //━━━━━━━━━━━━━━━━━━
    // ACTIVE PMH LABEL
    //━━━━━━━━━━━━━━━━━━

    if showPMLabels and not pmhSwept

        pmhLabelX = time + (pmLabelOffset * timeframe.in_seconds() * 1000)

        if na(pmhLabel)

            pmhLabel := label.new(
                 x = pmhLabelX,
                 y = pmh,
                 text = pmhText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pmhLabelColor,
                 textalign = text.align_left,
                 size = pmLabelSize == "Normal" ? size.normal : pmLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pmhLabel,
                 pmhLabelX,
                 pmh)



    
//━━━━━━━━━━━━━━━━━━
// SWEPT PMH LABEL
//━━━━━━━━━━━━━━━━━━

if pmhSwept and not na(pmhSweepTime)

    if not na(pmhLabel)

        label.delete(pmhLabel)
        pmhLabel := na


    if na(pmhSweptLabel)

        pmhSweptLabel := label.new(
             x = pmhSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             y = pmh,
             text = "PMH X",
             xloc = xloc.bar_time,
             style = label.style_none,
             textcolor = sweptLabelColor,
             textalign = text.align_left,
             size = size.normal)

    else

        label.set_xy(
             pmhSweptLabel,
             pmhSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             pmh)



//━━━━━━━━━━━━━━━━━━
// DRAW PML
//━━━━━━━━━━━━━━━━━━

if showPML and showPMLevels and not na(pml)

    pmlLineEndX = pmlSwept and not na(pmlSweepTime) ? pmlSweepTime : time + (pmLabelOffset * timeframe.in_seconds() * 1000)

    pmlText = pmLabelFormat == "Full" ? "Previous Month Low" : "PML"



    if na(pmlLine)

        pmlLine := line.new(
             x1 = pmlTime,
             y1 = pml,
             x2 = pmlLineEndX,
             y2 = pml,
             xloc = xloc.bar_time,
             color = pmlSwept ? color.new(pmlColor, 60) : pmlColor,
             width = monthLineWidth,
             style = pmlSwept ? line.style_dotted : line.style_solid)

    else

        line.set_xy1(
             pmlLine,
             pmlTime,
             pml)

        line.set_xy2(
             pmlLine,
             pmlLineEndX,
             pml)

        line.set_color(
             pmlLine,
             pmlSwept ? color.new(pmlColor, 60) : pmlColor)

        line.set_style(
             pmlLine,
             pmlSwept ? line.style_dotted : line.style_solid)



    //━━━━━━━━━━━━━━━━━━
    // ACTIVE PML LABEL
    //━━━━━━━━━━━━━━━━━━

    if showPMLabels and not pmlSwept

        pmlLabelX = time + (pmLabelOffset * timeframe.in_seconds() * 1000)

        if na(pmlLabel)

            pmlLabel := label.new(
                 x = pmlLabelX,
                 y = pml,
                 text = pmlText,
                 xloc = xloc.bar_time,
                 style = label.style_none,
                 textcolor = pmlLabelColor,
                 textalign = text.align_left,
                 size = pmLabelSize == "Normal" ? size.normal : pmLabelSize == "Small" ? size.small : size.tiny)

        else

            label.set_xy(
                 pmlLabel,
                 pmlLabelX,
                 pml)



    
//━━━━━━━━━━━━━━━━━━
// SWEPT PML LABEL
//━━━━━━━━━━━━━━━━━━

if pmlSwept and not na(pmlSweepTime)

    if not na(pmlLabel)

        label.delete(pmlLabel)
        pmlLabel := na


    if na(pmlSweptLabel)

        pmlSweptLabel := label.new(
             x = pmlSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             y = pml,
             text = "PML X",
             xloc = xloc.bar_time,
             style = label.style_none,
             textcolor = sweptLabelColor,
             textalign = text.align_left,
             size = size.normal)

    else

        label.set_xy(
             pmlSweptLabel,
             pmlSweepTime - (sweepXOffset * timeframe.in_seconds() * 1000),
             pml)   
                 
            
        
  
